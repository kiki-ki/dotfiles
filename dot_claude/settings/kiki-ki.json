{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git checkout -b *)",
      "Bash(git switch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git stash *)",
      "Bash(git tag *)",
      "Bash(git remote *)",
      "Bash(git rev-parse *)",
      "Bash(git ls-files*)",
      "Bash(git blame *)",
      "Bash(git shortlog *)",
      "Bash(git config --get *)",
      "Bash(git config --list*)",
      "Bash(git config --show-origin *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(gh repo view*)",
      "Bash(gh repo clone*)",
      "Bash(gh auth status*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(date *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(jq *)",
      "Bash(chezmoi *)",
      "Bash(tr *)",
      "Bash(cut *)",
      "Bash(tee *)",
      "Bash(true)",
      "Bash(test *)"
    ],
    "deny": [
      "Bash(curl *|*bash*)",
      "Bash(curl *|*sh*)",
      "Bash(wget *|*bash*)",
      "Bash(wget *|*sh*)",
      "Bash(git push --force*)",
      "Bash(git push *--force*)",
      "Bash(git push *--delete*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(git restore *)",
      "Bash(git checkout -- *)",
      "Bash(git checkout . *)",
      "Bash(git stash drop*)",
      "Bash(git reflog expire*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr close*)",
      "Bash(gh issue close*)",
      "Bash(find *-exec *)",
      "Bash(find *-execdir *)",
      "Bash(find *-delete*)",
      "Bash(rm -r*)",
      "Bash(rm -f*)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.kube/**)",
      "Edit(~/.gnupg/**)",
      "Edit(/etc/**)"
    ]
  },
  "language": "Japanese",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py"
  }
}
